{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./examples/*"],
      "element-plus-lab": ["../packages/element-plus-lab/index.ts"]
    },
    "types": ["vite/client", "vue-vine/macros", "unplugin-icons/types/vue", "unplugin-turbo-console/client"]
  },
  "include": [
    "**/*.d.ts",
    "examples/**/*.ts",
    "examples/**/*.tsx",
    "examples/**/*.vue",
    "examples/**/*.vine.ts",
    ".vitepress/**/*.ts",
    ".vitepress/**/*.mts",
    ".vitepress/**/*.vue",
    ".vitepress/**/*.d.ts"
  ]
}
