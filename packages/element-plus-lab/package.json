{
  "name": "element-plus-lab",
  "type": "module",
  "version": "0.1.0",
  "description": "A business component library based on Element Plus",
  "author": "xjxl520303 <xjxl520303@gmail.com",
  "license": "MIT",
  "homepage": "https://element-plus-lab-docs.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xjxl520303/element-plus-lab.git"
  },
  "bugs": {
    "url": "https://github.com/xjxl520303/element-plus-lab/issues"
  },
  "keywords": [
    "element-plus",
    "element",
    "component library",
    "cz-git",
    "portal-vue",
    "lefthook",
    "mockoon",
    "turborepo",
    "vitepress",
    "vue-use",
    "vue-vine",
    "vue"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/es/index.d.ts",
        "default": "./dist/es/index.mjs"
      },
      "require": {
        "types": "./dist/es/index.d.cts",
        "default": "./dist/lib/index.cjs"
      }
    },
    "./es": {
      "types": "./dist/es/index.d.ts",
      "import": "./dist/es/index.mjs"
    },
    "./lib": {
      "types": "./dist/es/index.d.ts",
      "require": {
        "types": "./dist/es/index.d.cts",
        "default": "./dist/lib/index.cjs"
      }
    },
    "./full": {
      "types": "./dist/es/index.d.ts",
      "import": "./dist/index.full.cjs",
      "require": "./dist/index.full.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "dist/lib/index.cjs",
  "module": "dist/es/index.mjs",
  "unpkg": "dist/index.full.cjs",
  "jsdelivr": "dist/index.full.cjs",
  "types": "dist/es/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "element-plus": "^2.13.0",
    "portal-vue": "^3.0.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@vueuse/core": "catalog:vue",
    "ulid": "catalog:vue"
  },
  "devDependencies": {
    "@types/node": "catalog:cli",
    "portal-vue": "catalog:vue",
    "ulid": "catalog:vue",
    "vue": "catalog:vue"
  }
}
